{
  "name": "logospos-print-agent",
  "version": "1.0.0",
  "description": "Agente de impresión local para LogosPOS — bridges HTTP (Angular) a TCP raw (impresoras ESC/POS)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "gen-cert": "node gen-cert.js",
    "build": "powershell -ExecutionPolicy Bypass -File build.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "postject": "^1.0.0-alpha.6"
  },
  "keywords": [
    "pos",
    "thermal",
    "printer",
    "escpos"
  ],
  "license": "MIT"
}
